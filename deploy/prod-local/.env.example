# prod-local environment variables — copy to .env and fill in real values.
# docker compose reads .env automatically when run from this directory.

# Whisper model size: tiny | base | small | medium | large
# Larger models are more accurate but slower and require more RAM/VRAM.
ASR_MODEL=small

# HuggingFace token — required for speaker diarization (whisperx + pyannote).
# Create a free token at https://huggingface.co/settings/tokens
# Accept the pyannote/speaker-diarization-3.1 model license before first use.
HF_TOKEN=
