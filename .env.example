# Environment variables for docker-compose files.
# Copy to .env in the PROJECT ROOT (not this directory) and fill in your values:
#   cp docker/.env.example .env

# HuggingFace token — required for speaker diarization with whisperx engine.
# Obtain at https://huggingface.co/settings/tokens and accept the pyannote
# speaker-diarization model licence at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here
